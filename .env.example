# Copy to .env and fill in values from Supabase Dashboard → Project Settings → API
# Never commit .env to git.
#
# Cloudflare "Deploy to Cloudflare" button: use `.dev.vars.example` as the full template
# (build-time VITE_* + Worker runtime secrets). See docs/Cloudflare-Deploy.md.

# Client (embedded in browser bundle via Vite — safe to expose with RLS)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Server-only (local dev + production secrets — never prefix with VITE_)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: comma-separated emails granted admin on first sign-in to /admin
ADMIN_BOOTSTRAP_EMAILS=operator@yourcompany.com

# Public site URL (build-time). Used for controller QR codes, og:url, and share links.
# Set to your production host (Lovable, workers.dev, or custom domain).
VITE_APP_ORIGIN=https://sonar-deep-dives.lovable.app

# Optional: default Open Graph / Twitter card image (absolute HTTPS URL).
# VITE_OG_IMAGE_URL=https://cdn.example.com/sonar-og.png

# Optional: app console verbosity — silent | error | warn | debug (default: warn in dev, error in prod)
# VITE_LOG_LEVEL=warn
